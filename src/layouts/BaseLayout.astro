---
import { ViewTransitions } from 'astro:transitions'
import HeadSEO from './HeadSEO.astro'
import Header from './Header.astro'

interface Props {
  title?: string | undefined
  description?: string | undefined
}

const { title, description } = Astro.props
---

<html lang="en">
  <head>
    <HeadSEO title={title} description={description} />
    <ViewTransitions />
  </head>
  <body class="h-screen bg-background font-sans antialiased overflow-hidden flex flex-col">
    <div class="fixed inset-0 -z-50 pointer-events-none">
      <div class="absolute inset-0 bg-grid-pattern opacity-[0.03] dark:opacity-[0.04]"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-background/30" aria-hidden="true"></div>
    </div>

    <Header />
    <div class="min-h-0 flex-1 overflow-y-auto w-full">
      <slot />
    </div>

    <script is:inline>
      document.addEventListener('click', async function (e) {
        const btn = e.target.closest?.('[data-copy-email]');
        if (!btn) return
        const email = btn.getAttribute('data-copy-email');
        if (!email) return
        try {
          await navigator.clipboard.writeText(email)
          const prevHTML = btn.innerHTML;
          btn.innerHTML = '✔️';
          btn.setAttribute('title', 'Скопировано!');
          debugger
          setTimeout(() => { 
            btn.setAttribute('title', 'Скопировать email');
            btn.innerHTML = prevHTML;
          }, 2000)
        } catch (_) {}
      })
    </script>
  </body>
</html>

<style>
  .bg-grid-pattern {
    background-image: linear-gradient(to right, currentColor 1px, transparent 1px),
      linear-gradient(to bottom, currentColor 1px, transparent 1px);
    background-size: 32px 32px;
  }
</style>

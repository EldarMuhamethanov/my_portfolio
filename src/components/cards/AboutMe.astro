---
import Card from '../common/Card.astro'
---

<Card colSpan="md:col-span-1 sm:col-span-2" rowSpan="md:row-span-6" title="Обо мне">
  <div class="flex flex-col h-full gap-4">
    <!-- Приветствие -->
    <div class="flex flex-col gap-2">
      <h2 class="text-lg font-semibold">
        Привет, я Эльдар 👋
      </h2>
      <p class="text-sm leading-relaxed">
        Фронтенд разработчик, увлеченный созданием современных веб-приложений и исследованием новых технологий.
      </p>
    </div>

    <!-- Технический стек -->
    <div class="space-y-3">
      <h3 class="text-md font-bold">Технический стек</h3>
      <div class="flex flex-wrap gap-2">
        <span class="tech-tag px-3 py-1.5 text-xs font-medium bg-primary/10 text-primary rounded-full border border-primary/20 transition-transform duration-200 hover:scale-105 motion-reduce:hover:scale-100">TypeScript</span>
        <span class="tech-tag px-3 py-1.5 text-xs font-medium bg-primary/10 text-primary rounded-full border border-primary/20 transition-transform duration-200 hover:scale-105 motion-reduce:hover:scale-100">React</span>
        <span class="tech-tag px-3 py-1.5 text-xs font-medium bg-primary/10 text-primary rounded-full border border-primary/20 transition-transform duration-200 hover:scale-105 motion-reduce:hover:scale-100">MobX</span>
        <span class="tech-tag px-3 py-1.5 text-xs font-medium bg-primary/10 text-primary rounded-full border border-primary/20 transition-transform duration-200 hover:scale-105 motion-reduce:hover:scale-100">Next.js</span>
        <span class="tech-tag px-3 py-1.5 text-xs font-medium bg-primary/10 text-primary rounded-full border border-primary/20 transition-transform duration-200 hover:scale-105 motion-reduce:hover:scale-100">Web3</span>
        <span class="tech-tag px-3 py-1.5 text-xs font-medium bg-primary/10 text-primary rounded-full border border-primary/20 transition-transform duration-200 hover:scale-105 motion-reduce:hover:scale-100">Solidity</span>
      </div>
    </div>

    <!-- Опыт -->
    <div class="space-y-3">
      <h3 class="text-md font-bold">Что я делаю</h3>
      <ul class="space-y-2">
        <li class="flex items-center gap-2 text-sm">
          <span class="text-primary/70">▹</span> Разрабатываю современные веб-приложения
        </li>
        <li class="flex items-center gap-2 text-sm">
          <span class="text-primary/70">▹</span> Создаю отзывчивые пользовательские интерфейсы
        </li>
        <li class="flex items-center gap-2 text-sm">
          <span class="text-primary/70">▹</span> Работаю с блокчейн технологиями
        </li>
      </ul>
    </div>

    <!-- Интересы -->
    <div class="space-y-3">
      <h3 class="text-md font-bold">Вне работы</h3>
      <div class="flex flex-wrap gap-3">
        <div class="flex items-center gap-1 text-sm">
          <span class="text-xl">🏂</span>
          <span>Сноуборд</span>
        </div>
        <div class="flex items-center gap-1 text-sm">
          <span class="text-xl">🗺️</span>
          <span>Путешествия</span>
        </div>
        <div class="flex items-center gap-1 text-sm">
          <span class="text-xl">🧠</span>
          <span>Квизы</span>
        </div>
        <div class="flex items-center gap-1 text-sm">
          <span class="text-xl">🎮</span>
          <span>Видеоигры</span>
        </div>
      </div>
    </div>
  </div>
</Card>
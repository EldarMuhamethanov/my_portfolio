---
import Card from '../common/Card.astro'
import { Button } from '../ui/button'
import { LINKS } from '../../lib/constants'
import { Icons } from '../../lib/icons'

const GithubIcon = Icons['github'];
const EmailIcon = Icons['email'];

---

<Card colSpan="lg:col-span-3 md:col-span-2 sm:col-span-2" rowSpan="lg:row-span-4 md:row-span-2" variant='default'>
  <div class="flex h-full w-full overflow-hidden relative">

    <div class="flex flex-col justify-between gap-6 z-10 w-full">
      <div class="flex h-full flex-col">
        <!-- Анимированный заголовок -->
        <h6 class="m-0 text-sm font-medium tracking-wider uppercase animate-fade-in">
          Добро пожаловать
        </h6>
        
        <!-- Основной текст с улучшенной типографикой -->
        <div class="mt-4 space-y-4">
          <p class="m-0 text-2xl font-light leading-relaxed">
            Привет! Я <span class="font-bold text-primary relative inline-block">
              Эльдар
              <span class="absolute bottom-0 left-0 w-full h-1 bg-primary/40 dark:bg-primary/50 transform -skew-x-12 rounded-full" aria-hidden="true"></span>
            </span> — фронтенд-разработчик, который превращает пиксели в эмоции, а код в удовольствие от использования.
          </p>
          
          <p class="text-lg leading-relaxed text-foreground/90">
            Создаю интерфейсы, в которые влюбляются пользователи, и решения, которыми гордятся клиенты. С 
            <span class="font-semibold text-primary">React</span> мы на "ты", 
            <span class="font-semibold text-primary">TypeScript</span> знаю как свои пять пальцев, 
            а чистый код — моё второе имя.
          </p>
        </div>
      </div>

      <!-- Улучшенные кнопки социальных сетей -->
      <div class="flex flex-wrap gap-3 mb-2 ml-2">
        <a 
          href={LINKS.github} 
          aria-label="github profile" 
          target="_blank"
          class="inline-flex transition-transform duration-200 hover:scale-[1.02] active:scale-[0.98]"
        >
          <Button 
            className="bg-foreground hover:bg-foreground/90 text-background rounded-xl px-6 py-3 flex items-center gap-2 shadow-md hover:shadow-glow-sm transition-shadow duration-200"
          >
            <GithubIcon/>
            <span class="hidden md:inline">GitHub</span>
          </Button>
        </a>

        <a 
          href={LINKS.mail} 
          aria-label="mail profile" 
          target="_blank"
          class="inline-flex transition-transform duration-200 hover:scale-[1.02] active:scale-[0.98]"
        >
          <Button 
            className="bg-primary hover:bg-primary/90 text-primary-foreground rounded-xl px-6 py-3 flex items-center gap-2 shadow-md hover:shadow-glow-sm transition-shadow duration-200"
          >
            <EmailIcon/>
            <span class="hidden md:inline">Email</span>
          </Button>
        </a>
      </div>
    </div>

    <!-- Улучшенное изображение с анимацией -->
    <img
      width="300"
      height="300"
      src="me.png"
      class="pointer-events-none absolute bottom-[-50px] right-[-130px] z-[1] max-h-[300px] w-auto select-none 
        opacity-90 transition-transform duration-300 hover:scale-[1.03]
        md:relative md:bottom-auto md:right-auto md:z-auto md:opacity-100 mt-10
        animate-float drop-shadow-lg"
      alt="memoji of Eldar"
    />
  </div>
</Card>

<style>
  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  .animate-fade-in {
    animation: fade-in 0.5s ease-out forwards;
  }
</style>
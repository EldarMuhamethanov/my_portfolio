---
interface Props {
  title: string
  description?: string
  as?: 'h1' | 'h2'
}

const { title, description, as: Tag = 'h1' } = Astro.props
---

<div class="relative py-14 sm:py-16">
  <div class="max-w-3xl mx-auto text-center px-4">
    <Tag class="scroll-m-20 text-4xl sm:text-5xl font-bold tracking-tight text-foreground letter-spacing-tight">
      {title}
    </Tag>
    {description && (
      <p class="mt-4 text-lg sm:text-xl text-muted-foreground leading-relaxed max-w-2xl mx-auto">
        {description}
      </p>
    )}
  </div>
</div>

<style>
  .letter-spacing-tight {
    letter-spacing: -0.02em;
  }
</style>

---
interface Props {
  id: string;
  name: string;
  photo: string;
  shortDescription: string;
}

const { id, name, photo, shortDescription } = Astro.props;
---

<a 
  href={`/project/${id}`}
  class="group/card block h-full rounded-2xl overflow-hidden bg-card border border-border/80 transition-all duration-300 hover:border-primary/30 hover:shadow-glow-sm hover:-translate-y-0.5"
>
  <div class="flex flex-col h-full">
    <div class="relative aspect-[16/9] overflow-hidden">
      <img
        src={photo}
        alt={name}
        class="object-cover w-full h-full transition-transform duration-500 ease-out group-hover/card:scale-105"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-card/60 to-transparent opacity-0 group-hover/card:opacity-100 transition-opacity duration-300 pointer-events-none" aria-hidden="true"></div>
    </div>
    
    <div class="flex flex-col flex-grow p-6">
      <h3 class="text-xl font-semibold tracking-tight mb-2 line-clamp-1 text-foreground">{name}</h3>
      <p class="text-muted-foreground line-clamp-3 flex-grow text-sm leading-relaxed">
        {shortDescription}
      </p>
      <div class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-primary group-hover/card:gap-2 transition-[gap] duration-200">
        Подробнее
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          class="w-4 h-4 transition-transform duration-200 group-hover/card:translate-x-0.5" 
          viewBox="0 0 20 20" 
          fill="currentColor"
          aria-hidden="true"
        >
          <path 
            fill-rule="evenodd" 
            d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" 
            clip-rule="evenodd"
          />
        </svg>
      </div>
    </div>
  </div>
</a>

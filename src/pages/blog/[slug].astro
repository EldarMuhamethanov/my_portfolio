---
import { getCollection, type CollectionEntry } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import BottomLayout from '../../layouts/BottomLayout.astro'
import BlogArticleLayout from '../../components/blog/BlogArticleLayout.astro'

export async function getStaticPaths() {
  const entries = await getCollection('blog')
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.(mdx?|md)$/, '') },
    props: { entry },
  }))
}

type Props = { entry: CollectionEntry<'blog'> }
const { entry } = Astro.props as Props
const { Content, headings } = await entry.render()
const { title, description, pubDate, tags } = entry.data
---

<BaseLayout
  title={`${title} — Блог | Eldar Muhamethanov`}
  description={description}
>
  <main
    class="relative flex min-h-[80vh] flex-auto flex-col"
    transition:animate="slide"
  >
    <div class="pb-5 pt-14">
      <div class="mx-auto w-full max-w-screen-xl px-5">
        <BlogArticleLayout headings={headings}>
          <div class="mb-4">
            <a
              href="/blog"
              class="text-sm font-medium text-primary hover:underline"
            >
              ← Все статьи
            </a>
          </div>
          <header class="mb-8">
            <h1
              class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl"
            >
              {title}
            </h1>
            <div class="mt-2 flex flex-wrap items-center gap-3">
              <time
                datetime={pubDate.toISOString()}
                class="block text-sm text-muted-foreground"
              >
                {
                  pubDate.toLocaleDateString('ru-RU', {
                    day: 'numeric',
                    month: 'long',
                    year: 'numeric',
                  })
                }
              </time>
              {tags && tags.length > 0 && (
                <ul class="flex flex-wrap gap-1.5">
                  {tags.map((tag) => (
                    <li class="inline-flex items-center gap-1 text-[11px] font-medium uppercase tracking-wide rounded-full bg-primary/10 px-2.5 py-1 text-primary border border-primary/30 shadow-[0_0_0_1px_rgba(255,255,255,0.03)]">
                      <span class="w-1.5 h-1.5 rounded-full bg-primary/70" aria-hidden="true" />
                      {tag}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </header>
          <div
            class="prose prose-neutral dark:prose-invert prose-headings:font-bold prose-pre:rounded-xl prose-code:rounded prose-code:px-1 prose-code:py-0.5 prose-code:before:content-none prose-code:after:content-none max-w-none"
          >
            <Content />
          </div>
        </BlogArticleLayout>
      </div>
    </div>
    <BottomLayout size="lg">
      <div class="border-t border-border pt-8">
        <a
          href="/blog"
          class="text-sm font-medium text-primary hover:underline"
        >
          ← Все статьи
        </a>
      </div>
    </BottomLayout>
  </main>
</BaseLayout>

<style is:global>
  .prose pre {
    overflow-x: auto;
    overflow-y: hidden;
    max-width: 85vw;
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro'
import TopLayout from '../../layouts/TopLayout.astro'
import BottomLayout from '../../layouts/BottomLayout.astro'
import PageTitle from '../../components/common/PageTitle.astro'

const BLOG_TITLE = 'Блог'
const BLOG_DESCRIPTION = 'Заметки о разработке, инструментах и опыте'
---

<BaseLayout title={`${BLOG_TITLE} — Eldar Muhamethanov`} description={BLOG_DESCRIPTION}>
  <main class="flex min-h-[80vh] flex-auto flex-col relative" transition:animate="slide">
    <TopLayout>
      <PageTitle title={BLOG_TITLE} description={BLOG_DESCRIPTION} />
    </TopLayout>

    <BottomLayout size="lg">
      <div class="flex flex-col items-center justify-center py-16 px-4 text-center max-w-md mx-auto">
        <div class="w-20 h-20 rounded-2xl bg-muted/50 flex items-center justify-center mb-6" aria-hidden="true">
          <svg class="w-10 h-10 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-foreground mb-2">Здесь скоро появятся статьи</h2>
        <p class="text-muted-foreground leading-relaxed">
          Заметки о фронтенде, инструментах и опыте — пока раздел в разработке. Следите за обновлениями.
        </p>
      </div>
    </BottomLayout>
  </main>
</BaseLayout>

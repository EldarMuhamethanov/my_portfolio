---
import BaseLayout from '../layouts/BaseLayout.astro'
import IntroCard from '../components/cards/IntroCard.astro'
import AboutMe from '../components/cards/AboutMe.astro'
import Card from '../components/common/Card.astro'
import TimeZoneCard from '../components/cards/TimeZoneCard.astro'
import ContactsCard from '../components/cards/ContactsCard.astro'
import Now from '../components/cards/Now.astro'
import CVCard from '../components/cards/CVCard.astro'
import ExperienceCard from '../components/cards/ExperienceCard.astro'
import StudyCard from '../components/cards/StudyCard.astro'
import GitHubActivityCard from '../components/cards/GitHubActivityCard.astro'
---

<script>
  import { stagger, spring, timeline, type TimelineDefinition } from 'motion'
  import { loaderAnimation } from '../lib/constants'

  const cards = document.querySelectorAll<HTMLElement>('.card-animate')

  const sequence = [
    loaderAnimation,
    [
      cards,
      { y: ['40%', '0%'], opacity: [0, 1] },
      {
        at: '-0.1',
        duration: 0.4,
        delay: stagger(0.3),
        easing: spring({ velocity: 100, stiffness: 50, damping: 10 }),
      },
    ],
  ]

  await timeline(sequence as TimelineDefinition).finished
  cards.forEach((card) => {
    card.style.transform = ''
    card.style.opacity = ''
  })
</script>

<BaseLayout
  title="Eldar Muhamethanov - Frontend Developer"
  description="Eldar Muhamethanov - Frontend Developer - Portfolio, Projects, CV, About Me, Contact, Timezone, Now, Experience, Tattoo, Study"
>
  <div
    slot="loader"
    class="loader fixed inset-0 z-50 flex h-screen w-screen items-center justify-center bg-background/95 backdrop-blur-sm"
  >
    <div class="flex flex-col items-center gap-6">
      <div class="relative">
        <div
          class="h-14 w-14 animate-spin rounded-full border-2 border-muted border-t-primary"
          aria-hidden="true"
        >
        </div>
        <div
          class="absolute inset-0 h-14 w-14 animate-glow-pulse rounded-full bg-primary/5"
          aria-hidden="true"
        >
        </div>
      </div>
      <span class="animate-fade-in-up text-lg font-medium text-muted-foreground"
        >Загрузка...</span
      >
    </div>
  </div>

  <div class="pointer-events-none fixed inset-0 -z-50 overflow-hidden">
    <div
      class="bg-grid-pattern absolute inset-0 opacity-[0.03] dark:opacity-[0.04]"
    >
    </div>
    <div
      class="bg-primary/8 absolute -right-40 -top-40 h-80 w-80 animate-glow-pulse rounded-full blur-3xl"
    >
    </div>
    <div
      class="bg-primary/8 absolute -bottom-40 -left-40 h-80 w-80 animate-glow-pulse rounded-full blur-3xl"
      style="animation-delay: 1.5s"
    >
    </div>
  </div>

  <main
    class="relative m-auto grid w-full max-w-7xl gap-3 overflow-hidden p-3 sm:gap-4 sm:p-4 md:grid-cols-2 md:gap-6 md:p-6 lg:grid-cols-4 lg:grid-rows-4 lg:gap-8"
  >
    <IntroCard />
    <AboutMe />
    <CVCard />
    <Card
      colSpan="md:col-span-1"
      rowSpan="md:row-span-2"
      title="Блог"
      href="/blog"
      body="Заметки о разработке и не только"
    />
    <Card
      colSpan="md:col-span-1"
      rowSpan="md:row-span-2"
      title="Портфолио и проекты"
      href="/portfolio"
      body="Мои pet-проекты"
    />
    <Now />
    <TimeZoneCard />
    <ContactsCard />
    <ExperienceCard />
    <StudyCard />
    <GitHubActivityCard />
  </main>
</BaseLayout>

<style>
  .bg-grid-pattern {
    background-image: radial-gradient(
        circle at center,
        currentColor 1px,
        transparent 1px
      ),
      linear-gradient(to right, currentColor 1px, transparent 1px);
    background-size:
      40px 40px,
      40px 40px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 70%);
  }
</style>
